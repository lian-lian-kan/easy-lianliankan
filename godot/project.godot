; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.

config_version=4

[application]

config/name="Lianliankan Godot Web"
run/main_scene="res://scenes/Main.tscn"
config/icon="res://icon.svg"

[display]

window/size/width=1280
window/size/height=720
window/stretch/mode="disabled"
window/stretch/aspect="expand"

[autoload]

AudioManager="*res://scripts/audio_manager.gd"
CoinsManager="*res://scripts/coins_manager.gd"
EnergyManager="*res://scripts/energy_manager.gd"
DailyRewardManager="*res://scripts/daily_reward_manager.gd"
ThemeManager="*res://scripts/theme_manager.gd"
LeaderboardManager="*res://scripts/leaderboard_manager.gd"
ShopManager="*res://scripts/shop_manager.gd"

[debug]

gdscript/warnings/treat_warnings_as_errors=false
